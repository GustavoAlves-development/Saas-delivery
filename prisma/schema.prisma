generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Empresa {
  id                    String            @id @default(cuid())
  nome                  String
  slug                  String            @unique
  telefoneWhatsapp      String
  taxaEntrega           Decimal           @default(0) @db.Decimal(10, 2)
  imagemPerfil          String?
  imagemBanner          String?
  horarioFuncionamento  String?
  paletaCor             String            @default("rose")
  corFundo              String            @default("#f9fafb")
  tipo                  TipoEmpresa       @default(LANCHONETE)
  feedbackWhatsapp      Boolean           @default(true)
  impressaoAutomatica   Boolean           @default(false)
  plano                 String            @default("basico")
  statusMensalidade     StatusMensalidade @default(TRIAL)
  vencimentoMensalidade DateTime?
  valorMensalidade      Decimal           @default(99.90) @db.Decimal(10, 2)
  criadoEm              DateTime          @default(now())
  atualizadoEm          DateTime          @updatedAt

  categorias      Categoria[]
  produtos        Produto[]
  pedidos         Pedido[]
  usuarios        Usuario[]
  acompanhamentos Acompanhamento[]

  @@map("empresas")
}

model SuperAdmin {
  id            String    @id @default(cuid())
  email         String    @unique
  senha         String
  sessionToken  String?   @unique
  sessionExpiry DateTime?
  criadoEm      DateTime  @default(now())

  @@map("super_admins")
}

model Usuario {
  id        String   @id @default(cuid())
  email     String   @unique
  senha     String
  empresaId String
  empresa   Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  criadoEm DateTime @default(now())

  @@map("usuarios")
}

model Categoria {
  id         String           @id @default(cuid())
  nome       String
  ordem      Int              @default(0)
  empresaId  String
  empresa    Empresa          @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  produtos   Produto[]
  adicionais Acompanhamento[] @relation("AdicionalCategorias")

  @@map("categorias")
}

model Produto {
  id          String    @id @default(cuid())
  nome        String
  descricao   String?
  preco       Decimal   @db.Decimal(10, 2)
  precoMedio  Decimal?  @db.Decimal(10, 2)
  precoMini   Decimal?  @db.Decimal(10, 2)
  tiposPao    String[]
  imagemUrl   String?
  ativo       Boolean   @default(true)
  categoriaId String
  categoria   Categoria @relation(fields: [categoriaId], references: [id], onDelete: Restrict)
  empresaId   String
  empresa     Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  criadoEm   DateTime  @default(now())

  @@map("produtos")
}

model Pedido {
  id              String       @id @default(cuid())
  empresaId       String
  empresa         Empresa      @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  nomeCliente     String
  telefoneCliente String
  endereco        String
  formaPagamento  String
  observacoes     String?
  total           Decimal      @db.Decimal(10, 2)
  status          StatusPedido @default(RECEBIDO)
  itens           ItemPedido[]
  criadoEm       DateTime     @default(now())
  atualizadoEm   DateTime     @updatedAt

  @@map("pedidos")
}

model Acompanhamento {
  id         String              @id @default(cuid())
  nome       String
  preco      Decimal             @default(0) @db.Decimal(10, 2)
  imagemUrl  String?
  tipo       TipoAcompanhamento  @default(ACOMPANHAMENTO)
  ativo      Boolean             @default(true)
  empresaId  String
  empresa    Empresa             @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  categorias Categoria[]         @relation("AdicionalCategorias")

  @@map("acompanhamentos")
}

model ItemPedido {
  id          String  @id @default(cuid())
  pedidoId    String
  pedido      Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produtoId   String
  nomeProduto String
  preco       Decimal @db.Decimal(10, 2)
  quantidade  Int

  @@map("itens_pedido")
}

enum StatusPedido {
  RECEBIDO
  EM_PREPARO
  DESPACHADO
  ENTREGUE
  CANCELADO
}

enum StatusMensalidade {
  TRIAL
  EM_DIA
  VENCIDA
  CANCELADA
}

enum TipoEmpresa {
  LANCHONETE
  PIZZARIA
  RESTAURANTE
}

enum TipoAcompanhamento {
  ADICIONAL
  ACOMPANHAMENTO
}
