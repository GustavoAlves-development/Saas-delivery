generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Empresa {
  id                String     @id @default(cuid())
  nome              String
  slug              String     @unique
  telefoneWhatsapp  String
  taxaEntrega          Decimal   @default(0) @db.Decimal(10, 2)
  imagemPerfil         String?
  imagemBanner         String?
  horarioFuncionamento String?
  criadoEm             DateTime  @default(now())
  atualizadoEm         DateTime  @updatedAt

  categorias        Categoria[]
  produtos          Produto[]
  pedidos           Pedido[]
  usuarios          Usuario[]

  @@map("empresas")
}

model Usuario {
  id        String   @id @default(cuid())
  email     String   @unique
  senha     String
  empresaId String
  empresa   Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  criadoEm DateTime @default(now())

  @@map("usuarios")
}

model Categoria {
  id        String    @id @default(cuid())
  nome      String
  empresaId String
  empresa   Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  produtos  Produto[]

  @@map("categorias")
}

model Produto {
  id          String    @id @default(cuid())
  nome        String
  descricao   String?
  preco       Decimal   @db.Decimal(10, 2)
  imagemUrl   String?
  ativo       Boolean   @default(true)
  categoriaId String
  categoria   Categoria @relation(fields: [categoriaId], references: [id], onDelete: Restrict)
  empresaId   String
  empresa     Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  criadoEm   DateTime  @default(now())

  @@map("produtos")
}

model Pedido {
  id              String       @id @default(cuid())
  empresaId       String
  empresa         Empresa      @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  nomeCliente     String
  telefoneCliente String
  endereco        String
  formaPagamento  String
  observacoes     String?
  total           Decimal      @db.Decimal(10, 2)
  status          StatusPedido @default(RECEBIDO)
  itens           ItemPedido[]
  criadoEm       DateTime     @default(now())
  atualizadoEm   DateTime     @updatedAt

  @@map("pedidos")
}

model ItemPedido {
  id         String  @id @default(cuid())
  pedidoId   String
  pedido     Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produtoId  String
  nomeProduto String
  preco      Decimal @db.Decimal(10, 2)
  quantidade Int

  @@map("itens_pedido")
}

enum StatusPedido {
  RECEBIDO
  EM_PREPARO
  DESPACHADO
  ENTREGUE
  CANCELADO
}
